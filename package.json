{
  "name": "barber-software",
  "version": "1.0.11",
  "description": "BarberOS - Gestion de barberia",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:signed": "electron-builder -c.win.forceCodeSigning=true -c.win.signAndEditExecutable=true",
    "release": "electron-builder --publish always"
  },
  "keywords": [],
  "author": "Lenning Hidalgo",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.leni021.barberos",
    "productName": "BarberOS",
    "artifactName": "${productName}.Setup.${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "frontend/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "BarberOS"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "leni021",
        "repo": "BarberOS"
      }
    ]
  }
}
